# Base environment shared by direnv-managed shells.
# `.envrc` may layer additional helpers on top, but this file is the common base.

source "$(cd "$(dirname "${BASH_SOURCE[0]:-${(%):-%x}}")" && pwd)/scripts/env-common.sh"
xsai_env_init

if declare -F log_status >/dev/null 2>&1; then
  log_status "Environment variables set successfully."
fi
